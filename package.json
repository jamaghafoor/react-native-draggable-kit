{
  "name": "react-native-draggable-kit",
  "version": "0.1.0",
  "description": "Production-grade drag-and-drop reordering for React Native lists. Powered by Reanimated worklets and Gesture Handler v2 for buttery-smooth 60fps animations on the UI thread.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!lib/typescript/src/__tests__"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "bob build",
    "release": "changeset publish",
    "version": "changeset version"
  },
  "keywords": [
    "react-native",
    "drag",
    "drop",
    "reorder",
    "sortable",
    "draggable",
    "list",
    "reanimated",
    "gesture-handler",
    "animation",
    "ui-thread"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jamaghafoor/react-native-draggable-kit.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jamaghafoor/react-native-draggable-kit/issues"
  },
  "homepage": "https://github.com/jamaghafoor/react-native-draggable-kit#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-gesture-handler": ">=2.9.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": false
    },
    "react-native-gesture-handler": {
      "optional": false
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.6.0",
    "react-test-renderer": "18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
